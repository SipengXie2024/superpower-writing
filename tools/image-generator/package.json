{
  "name": "@superpower-writing/image-generator",
  "version": "0.1.0",
  "private": true,
  "description": "Internal Codex-OAuth-backed image generator for paper figures (gpt-image-2). Not published.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "image-gen": "dist/cli.js"
  },
  "scripts": {
