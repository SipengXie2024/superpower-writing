# Secrets — NEVER commit
.env
.env.local
.env.*.local
.writing/secrets.local
**/secrets.local

# Writing working state
.writing/verify-cache.json
.writing/stash/
# .writing/ itself IS tracked — only caches/stashes are ignored

# Plugin-internal design history (kept locally, not published)
.planning/

# Python
__pycache__/
*.py[cod]
*.egg-info/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.venv/

# Editor
.vscode/
.idea/
*.swp
*.swo
.DS_Store

# Node (pyzotero upstream uses npx; transient installs)
node_modules/

# TypeScript build artifacts under tools/* (e.g. image-generator)
tools/*/dist/

# Local developer automation — not shipped with the plugin.
# The two hooks below are registered via .claude/settings.local.json
# (itself ignored by the global git ignore), not via hooks/hooks.json.
/CLAUDE.md
/agents/plugin-lint.md
/hooks/block-marketplace-writes.sh
/hooks/shellcheck-on-edit.sh
/skills/release-prep/
/skills/scaffold-component/
