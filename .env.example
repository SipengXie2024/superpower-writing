# superpower-writing environment template
# Copy to .env (which is gitignored) and fill in your own values.
# Get a Zotero API key at https://www.zotero.org/settings/keys

# ---- Zotero (required when metadata.yaml sets zotero.enabled: true) ----

# Your Zotero API key. Scope: read/write on your own library (and any group
# libraries you want to push citations into). Keep secret.
ZOTERO_API_KEY=

# Your numeric Zotero user ID (see https://www.zotero.org/settings/keys).
# Leave ZOTERO_GROUP_ID empty if you're using a personal library.
ZOTERO_USER_ID=

# Optional: for group/shared libraries, use the group ID instead of user ID.
# If both are set, ZOTERO_GROUP_ID wins.
ZOTERO_GROUP_ID=

# Optional: default collection key for per-paper scoping (override per-paper
# via .writing/metadata.yaml zotero.collection_key).
ZOTERO_DEFAULT_COLLECTION=
