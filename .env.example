# superpower-writing environment template
# Copy to .env (gitignored) and export these vars in your shell before
# launching Claude Code so the plugin's .mcp.json can pass them through
# to the zotero-mcp server.
#
# Get a Zotero API key at https://www.zotero.org/settings/keys

# ---- Zotero (required when metadata.yaml sets zotero.enabled: true) ----

# Your Zotero API key. Scope: read/write on the library you want to use.
ZOTERO_API_KEY=

# Your library ID. For a personal library this is the numeric user ID shown
# at https://www.zotero.org/settings/keys. For a group library this is the
# numeric group ID.
ZOTERO_LIBRARY_ID=

# "user" for a personal library, "group" for a group/shared library.
ZOTERO_LIBRARY_TYPE=user
